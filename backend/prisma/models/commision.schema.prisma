model CommissionSetting {
  id          String  @id @default(uuid())
  name        String  @default("Commission")
  role        String  @default("PLATFORM") // PLATFORM, BROKER, OWNER, STAFF
  description String?

  // Commission calculation type
  calcType    String  @default("PERCENTAGE") // PERCENTAGE or FLAT_AMOUNT

  // global platform-level percentage
  platformPercent Float

  // flat amount alternative (used when calcType = FLAT_AMOUNT)
  flatAmount  Float?

  // optional per-broker commission (global)
  brokerPercent Float?

  // Relation back to Property (1:1)
  propertyId String?        @unique
  property   Property?      @relation(fields: [propertyId], references: [id])
  type       CommissionType

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CommissionType {
  PLATFORM // global commission applied to all properties
  PROPERTY // commission specific to a property
}
